{
  "name": "developer-ui",
  "version": "1.0.0",
  "description": "Developer UI components",
  "main": "./src/index.js",
  "babel": {
    "presets": [
      "@babel/preset-env",
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ]
    ]
  },
  "scripts": {
    "server:build": "tsc",
    "server:run": "node --experimental-specifier-resolution=node dist/server.js",
    "start": "npm-run-all --sequential server:build server:run",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [
    "developer-ui"
  ],
  "dependencies": {
    "@babel/preset-env": "^7.17.10",
    "@material-ui/core": "^4.12.2",
    "@material-ui/icons": "^4.11.2",
    "prop-types": "^15.8.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "socket.io-client": "^4.5.1"
  },
  "devDependencies": {
    "@types/eslint": "^8.4.1",
    "@types/eslint-plugin-prettier": "^3.1.0",
    "@types/express": "^4.17.13",
    "@types/node": "^17.0.17",
    "@types/prettier": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^5.11.0",
    "@typescript-eslint/parser": "^5.11.0",
    "eslint": "^8.9.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "prettier-plugin-organize-imports": "^2.3.4",
    "typescript": "^4.5.5"
  }
}

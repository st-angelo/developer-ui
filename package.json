{
  "name": "developer-ui",
  "version": "0.0.36-beta",
  "description": "Collection of components and features meant only for development mode.",
  "main": "./src/index.js",
  "type": "module",
  "babel": {
    "presets": [
      "@babel/preset-env",
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ]
    ]
  },
  "scripts": {
    "push": "npm run build && cd ./dist && npm publish",
    "build": "npm run delete && npm run build:tsc && npm run build:copy-files",
    "build:tsc": "tsc",
    "build:copy-files": "node ./scripts/copyFiles.js",
    "delete": "del-cli --force ./dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [
    "developer-ui"
  ],
  "dependencies": {
    "@babel/preset-env": "^7.17.10",
    "@material-ui/core": "^4.12.2",
    "@material-ui/icons": "^4.11.2",
    "developer-published-language": "^1.0.0",
    "lodash.sortby": "^4.7.0",
    "prop-types": "^15.8.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-router": "^5.2.0",
    "react-router-dom": "^5.2.0",
    "react-toastify": "^9.0.3",
    "socket.io-client": "^4.5.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/eslint": "^8.4.1",
    "@types/eslint-plugin-prettier": "^3.1.0",
    "@types/express": "^4.17.13",
    "@types/lodash.sortby": "^4.7.7",
    "@types/node": "^17.0.17",
    "@types/prettier": "^2.4.4",
    "@types/react-router-dom": "^5.3.3",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.11.0",
    "@typescript-eslint/parser": "^5.11.0",
    "del-cli": "^4.0.1",
    "eslint": "^8.9.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "fs-extra": "^10.1.0",
    "glob": "^8.0.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.5.1",
    "prettier-plugin-organize-imports": "^2.3.4",
    "typescript": "^4.5.5"
  }
}
